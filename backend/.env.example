# ── 5 Cypress ClawHub Backend — Environment Variables ──────────────────────────
# Copy this to .env and fill in your values. NEVER commit .env to Git.

# ── Stripe ──────────────────────────────────────────────────────────────────────
# From https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...

# From https://dashboard.stripe.com/webhooks (your endpoint's signing secret)
STRIPE_WEBHOOK_SECRET=whsec_...

# ── SAM.gov ─────────────────────────────────────────────────────────────────────
# Federal Contracts skill uses USA Spending API (public, no API key needed)
# No configuration required for Contracts skill

# ── Database ────────────────────────────────────────────────────────────────────
# SQLite (default, no config needed):
# DATABASE_URL=5cypress_clawhub.db

# Postgres (production):
# DATABASE_URL=postgresql://user:pass@host:5432/clawhub

# ── Server ──────────────────────────────────────────────────────────────────────
# Set to "production" to disable the /stripe/test-create-key endpoint
ENVIRONMENT=dev

# Port for uvicorn (default 8000)
PORT=8000

# Public base URL of your VPS (for self-referencing in responses)
VPS_BASE_URL=https://api.5cypress.com

# ── Optional: Email delivery (for sending API keys after Stripe purchase) ────────
# Resend.com is recommended (free tier: 3k emails/mo)
# RESEND_API_KEY=re_...
# FROM_EMAIL=noreply@5cypress.com
